if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi

if [ -f .env ]; then
  dotenv .env
fi

# Auto-populate VERCEL_API_TOKEN from `vercel login`'s cached session, so
# `vercel env pull` / `vercel link` work without you needing to copy a
# token into .envrc.local. Matches mcclenaghan-app/.envrc behaviour.
if [ -z "${VERCEL_API_TOKEN:-}" ]; then
  for _candidate in \
    "$HOME/Library/Application Support/com.vercel.cli/auth.json" \
    "$HOME/.local/share/com.vercel.cli/auth.json"; do
    if [ -f "$_candidate" ] && command -v jq >/dev/null 2>&1; then
      _tok="$(jq -r '.token // empty' "$_candidate" 2>/dev/null)"
      if [ -n "$_tok" ]; then
        export VERCEL_API_TOKEN="$_tok"
        break
      fi
    fi
  done
  unset _candidate _tok
fi

if [ -f .envrc.local ]; then
  source_env .envrc.local
fi
